      "parameters": {
        "channel": "C_YOUR_CHANNEL_MANAGERS_CHANNEL",
        "text": "=:rotating_light: *ONBOARDING OVERDUE - 30 DAYS*\\n\\n*Partner:* {{ $json.partnerName }}\\n*Onboarding ID:* {{ $json.onboardingId }}\\n*Tier:* {{ $json.partnerTier }}\\n*Channel Manager:* {{ $json.channelManager }}\\n*Started:* {{ $json.onboardingStartedAt }}\\n\\n*This partner has NOT completed onboarding in 30 days.*\\n\\n*Escalating to Channel Director for review.*\\n\\nPossible actions:\\n:one: Schedule direct call with partner leadership\\n:two: Place partner in nurture track (reduced engagement)\\n:three: Re-evaluate partner fit for the program\\n\\n@channel Please review and take action.",
