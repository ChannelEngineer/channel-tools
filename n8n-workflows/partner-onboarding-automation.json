    {
      "id": "slack-day7",
      "name": "Slack - Day 7 Escalation",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2,
      "position": [1850, 100],
      "parameters": {
        "channel": "C_YOUR_CHANNEL_MANAGERS_CHANNEL",
        "text": "=:warning: *ONBOARDING ESCALATION - Day 7*\\n\\n*Partner:* {{ $json.partnerName }}\\n*Onboarding ID:* {{ $json.onboardingId }}\\n*Tier:* {{ $json.partnerTier }}\\n*Channel Manager:* {{ $json.channelManager }}\\n\\n*Partner has been onboarding for 7 days.*\\n\\n:white_square_button: Orientation completed? {{ $json.orientationCompleted }}\\n:white_square_button: Marketing meeting scheduled?\\n:white_square_button: Product listed on partner website?\\n\\n*Required Action:* Channel manager must contact partner TODAY. If no response within 48 hours, escalate to Channel Director.\\n\\nReview: https://n8n.navitools.net/workflow/onboarding-review?partner={{ $json.onboardingId }}",
        "username": "Onboarding Bot",
        "sendAsUser": false,
        "attachments": {}
      },
      "credentials": {
        "slackApi": "YOUR_SLACK_CREDENTIAL_ID"
      }
    },
    {
      "id": "email-day7",
      "name": "Email - Day 7 Urgent Follow-Up",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 1,
      "position": [1850, 250],
      "parameters": {
        "fromEmail": "channel@navitools.net",
        "toEmail": "={{ $json.partnerEmail }}",
        "subject": "=Don't Forget Your Onboarding Steps! ({{ $json.onboardingId }})",
        "text": "=Hi {{ $json.partnerName }},\\n\\nIt's been a week since you joined the NaviTools partner program and we want to make sure you're getting the full benefit of your partnership!\\n\\n=== REMAINING ONBOARDING STEPS ===\\n\\nIf you haven't completed these yet, now is the time:\\n\\n:one: *Orientation Meeting* - Get a personalized walkthrough of the portal, product demo, and program benefits\\n:two: *NFR Setup* - Access the software for free to build your expertise\\n:three: *Marketing Meeting* - Let us help you create promotions that drive leads\\n:four: *Product Listing* - Get listed in our partner locator by featuring our products on your website\\n\\n=== WHY COMPLETE ONBOARDING? ===\\n\\n- Access to partner-exclusive leads\\n- Deal registration with extra margin\\n- Co-marketing MDF funds\\n- Priority listing in partner locator\\n\\nYour channel manager ({{ $json.channelManager }}) is ready to help. Please respond to this email or call to schedule your remaining steps.\\n\\nBest,\\nChannel Team\\nNaviTools Partner Program",
        "options": {}
      },
      "credentials": {
        "smtp": "YOUR_GMAIL_SMTP_CREDENTIAL_ID"
      }
    },
