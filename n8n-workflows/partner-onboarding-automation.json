      "position": [2450, 400],
      "parameters": {
        "operation": "appendOrUpdate",
        "sheetId": "YOUR_GOOGLE_SHEET_ID",
        "sheetName": "PartnerOnboarding",
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
