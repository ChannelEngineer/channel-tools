    {
      "id": "email-day30",
      "name": "Email - Final Notice to Partner",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 1,
      "position": [2450, 250],
      "parameters": {
        "fromEmail": "channel@navitools.net",
        "toEmail": "={{ $json.partnerEmail }}",
        "subject": "=Action Required: Complete Your Partner Onboarding ({{ $json.onboardingId }})",
        "text": "=Hi {{ $json.partnerName }},\\n\\nIt's been 30 days since you joined the NaviTools partner program and we noticed your onboarding hasn't been completed yet.\\n\\n=== WHAT'S AT STAKE ===\\n\\nTo maintain active partner status and access the full benefits of the program, partners must complete onboarding within 30 days.\\n\\n*Benefits you may be missing:*\\n- Partner portal access with marketing collateral\\n- Lead distribution and deal registration\\n- MDF (Market Development Funds) eligibility\\n- Partner locator listing\\n- NFR software access\\n- 90-Day Jump Start promotion (extra 10% margin)\\n\\n=== GET BACK ON TRACK ===\\n\\nPlease contact your channel manager ({{ $json.channelManager }}) within the next 5 business days to complete your onboarding.\\n\\nIf we don't hear from you, your partner application may be placed in inactive status.\\n\\nWe're here to help you succeed — let's get you onboarded!\\n\\nBest,\\nChannel Team\\nNaviTools Partner Program",
        "options": {}
      },
      "credentials": {
        "smtp": "YOUR_GMAIL_SMTP_CREDENTIAL_ID"
      }
    },
