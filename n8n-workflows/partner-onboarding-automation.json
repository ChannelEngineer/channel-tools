      "name": "Slack - Day 3 Reminder",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2,
      "position": [1250, 100],
      "parameters": {
        "channel": "C_YOUR_PARTNER_OPS_CHANNEL",
        "text": "=:bell: Day 3 Onboarding Follow-Up\\n*Partner:* {{ $json.partnerName }}\\n*Onboarding ID:* {{ $json.onboardingId }}\\n*Tier:* {{ $json.partnerTier }}\\n*Channel Manager:* {{ $json.channelManager }}\\n\\n*Checklist:*\\n:white_square_button: Has orientation been scheduled?\\n:white_square_button: Has partner logged into portal?\\n:white_square_button: NFR license issued?\\n\\n*Action:* Contact partner to confirm progress and address any blockers.",
        "username": "Onboarding Bot",
        "sendAsUser": false,
        "attachments": {}
      },
      "credentials": {
        "slackApi": "YOUR_SLACK_CREDENTIAL_ID"
      }
    },
    {
      "id": "email-day3",
      "name": "Email - Day 3 Check-In",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 1,
      "position": [1250, 250],
      "parameters": {
        "fromEmail": "channel@navitools.net",
        "toEmail": "={{ $json.partnerEmail }}",
        "subject": "=Getting Started - Quick Check-In ({{ $json.onboardingId }})",
        "text": "=Hi {{ $json.partnerName }},\\n\\nJust checking in! We noticed it's been a few days since you joined the NaviTools partner program and we want to make sure everything is going smoothly.\\n\\n=== HAVE YOU COMPLETED THESE STEPS? ===\\n\\n:one: Logged into the partner portal?\\n:two: Scheduled your orientation meeting?\\n:three: Received your NFR software access?\\n\\nIf you need help with any of these, reply to this email or contact your channel manager ({{ $json.channelManager }}).\\n\\n=== QUICK TIP ===\\n\\nDon't forget about the 90-Day Jump Start promotion! Register your first deal within 90 days and earn an extra 10% margin. \\n\\nWe're here to help you succeed!\\n\\nBest,\\nChannel Team\\nNaviTools Partner Program",
        "options": {}
      },
      "credentials": {
        "smtp": "YOUR_GMAIL_SMTP_CREDENTIAL_ID"
      }
    },
    {
      "id": "sheets-day3",
