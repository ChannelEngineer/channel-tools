{
  "name": "Partner Onboarding - Automated Welcome & Milestone Follow-Up",
  "nodes": [
    {
      "id": "webhook-onboarding",
      "name": "Webhook - New Partner Onboarding",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [250, 300],
      "parameters": {
        "path": "partner-onboarding",
        "options": {},
        "httpMethod": "POST",
        "responseMode": "responseNode",
        "responseData": "firstInputJson"
      },
      "webhookId": "partner-onboarding-hook"
    },
    {
      "id": "format-onboarding",
      "name": "Format Onboarding Data",
      "type": "n8n-nodes-base.set",
      "typeVersion": 2,
      "position": [450, 300],
      "parameters": {
        "values": {
          "string": [
            {
              "name": "partnerName",
              "value": "={{ $json.body.partnerName }}"
            },
            {
              "name": "partnerEmail",
              "value": "={{ $json.body.partnerEmail }}"
            },
            {
              "name": "partnerTier",
              "value": "={{ $json.body.partnerTier }}"
            },
            {
              "name": "companyName",
              "value": "={{ $json.body.companyName || $json.body.partnerName }}"
            },
            {
              "name": "phone",
              "value": "={{ $json.body.phone || 'Not provided' }}"
            },
            {
              "name": "channelManager",
              "value": "={{ $json.body.channelManager || 'Unassigned' }}"
            },
            {
              "name": "portalUrl",
              "value": "={{ $json.body.portalUrl || 'https://partner.navitools.net' }}"
            },
            {
              "name": "portalPassword",
              "value": "={{ $json.body.portalPassword || 'Welcome123!' }}"
            },
            {
              "name": "onboardingId",
              "value": "={{ 'ONB-' + Date.now().toString(36).toUpperCase() + '-' + Math.random().toString(36).substring(2,6).toUpperCase() }}"
            },
            {
              "name": "status",
              "value": "Onboarding Started"
            },
            {
              "name": "onboardingStartedAt",
              "value": "={{ Date.now() }}"
            },
            {
              "name": "orientationScheduled",
              "value": "={{ $json.body.orientationScheduled || 'Not scheduled' }}"
            },
            {
              "name": "orientationCompleted",
              "value": "={{ $json.body.orientationCompleted || 'No' }}"
            }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "slack-new-partner",
      "name": "Slack - New Partner Onboarding",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2,
      "position": [650, 200],
      "parameters": {
        "channel": "C_YOUR_PARTNER_OPS_CHANNEL",
        "text": "=:rocket: New Partner Onboarding Started\\n*Partner:* {{ $json.partnerName }}\\n*Tier:* {{ $json.partnerTier }}\\n*Email:* {{ $json.partnerEmail }}\\n*Phone:* {{ $json.phone }}\\n*Channel Manager:* {{ $json.channelManager }}\\n*Onboarding ID:* {{ $json.onboardingId }}\\n\\n*Next Steps:*\\n1. Confirm partner website has products listed\\n2. Schedule orientation meeting within 48 hours\\n3. Setup NFR license access\\n4. Schedule marketing meeting after orientation\\n\\n:calendar: *Orientation:* {{ $json.orientationScheduled }}",
        "username": "Onboarding Bot",
        "sendAsUser": false,
        "attachments": {}
      },
      "credentials": {
        "slackApi": "YOUR_SLACK_CREDENTIAL_ID"
      }
    },
    {
      "id": "email-welcome",
      "name": "Email - Welcome & Portal Access",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 1,
      "position": [650, 350],
      "parameters": {
        "fromEmail": "channel@navitools.net",
        "toEmail": "={{ $json.partnerEmail }}",
        "subject": "=Welcome to the Partner Program! - {{ $json.onboardingId }}",
        "text": "=Hi {{ $json.partnerName }},\\n\\nWelcome to the NaviTools partner program! We're excited to have you on board as a {{ $json.partnerTier }} partner.\\n\\n=== YOUR PORTAL ACCESS ===\\n\\nPortal URL: {{ $json.portalUrl }}\\nYour Email: {{ $json.partnerEmail }}\\nTemporary Password: {{ $json.portalPassword }}\\n\\nPlease log in and change your password on first access.\\n\\n=== YOUR ONBOARDING CHECKLIST ===\\n\\n:one: Log into the partner portal and review your dashboard\\n:two: Complete the orientation meeting (scheduled: {{ $json.orientationScheduled }})\\n:three: Set up NFR (Not For Resale) software access\\n:four: Attend the marketing planning meeting\\n:five: List our products on your website\\n:six: Register your first deal (earn extra 10% Jump Start margin!)\\n\\n=== 90-DAY JUMP START PROMOTION ===\\n\\nAs a new partner, you qualify for our 90-Day Jump Start promotion:\\n- Extra 10% margin on all deals registered within your first 90 days\\n- Priority lead assignment\\n- Dedicated channel manager support\\n\\n=== NEXT STEPS ===\\n\\nYour channel manager ({{ $json.channelManager }}) will reach out within 24 hours to:\\n- Confirm your portal access\\n- Schedule your orientation meeting\\n- Discuss your first 90-day goals\\n\\nIf you have any questions, reply to this email or call {{ $json.phone }}.\\n\\nBest,\\nChannel Team\\nNaviTools Partner Program",
        "options": {}
      },
      "credentials": {
        "smtp": "YOUR_GMAIL_SMTP_CREDENTIAL_ID"
      }
    },
    {
      "id": "sheets-log-start",
      "name": "Log - Onboarding Started",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4,
      "position": [650, 500],
      "parameters": {
        "operation": "appendOrUpdate",
        "sheetId": "YOUR_GOOGLE_SHEET_ID",
        "sheetName": "PartnerOnboarding",
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "Onboarding ID": "={{ $json.onboardingId }}",
            "Partner Name": "={{ $json.partnerName }}",
            "Email": "={{ $json.partnerEmail }}",
            "Tier": "={{ $json.partnerTier }}",
            "Channel Manager": "={{ $json.channelManager }}",
            "Phone": "={{ $json.phone }}",
            "Status": "Onboarding Started",
            "Orientation Scheduled": "={{ $json.orientationScheduled }}",
            "Orientation Completed": "={{ $json.orientationCompleted }}",
            "Started At": "={{ $json.onboardingStartedAt }}",
            "Last Milestone": "Welcome Sent"
          }
        },
        "options": {
          "cellFormat": "USER_ENTERED"
        }
      },
      "credentials": {
        "googleSheets": "YOUR_GOOGLE_SHEETS_CREDENTIAL_ID"
      }
    },
    {
      "id": "wait-3-days",
